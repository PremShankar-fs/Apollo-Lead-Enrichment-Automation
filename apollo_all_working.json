    {
      "parameters": {
        "jsCode": "const person = $input.item.json;\nconst cleanDomain = $('Clean URL').item.json.clean_domain || '';\nconst staticData = $getWorkflowStaticData('node');\nstaticData.skippedDomains = staticData.skippedDomains || [];\n\nlet existingLeads = [];\ntry { existingLeads = $('Read Output Sheet').all().map(item => item.json); } catch(e) {}\n\nlet skip = false;\n\ntry {\n  const successes = $('Update Google Sheet').all();\n  if (successes.some(s => (s.json.company_url || '').includes(cleanDomain) || (s.json.clean_domain || '').includes(cleanDomain))) {\n    skip = true;\n  }\n} catch(e) {}\n\nif (staticData.skippedDomains.includes(cleanDomain)) { skip = true; }\n\nif (skip) {\n   return { json: { ...person, duplicate: true, skip_silently: true } };\n}\n\nlet exists = false;\nfor (let lead of existingLeads) {\n  if (lead.apollo_person_id && lead.apollo_person_id === person.id) { exists = true; break; }\n  if (lead.linkedin_url && person.linkedin_url && lead.linkedin_url === person.linkedin_url) { exists = true; break; }\n  if (lead.verified_email && person.email && lead.verified_email === person.email) { exists = true; break; }\n  if (lead.first_name && lead.first_name === person.first_name && lead.last_name === person.last_name && (lead.company_url || lead.clean_domain || '').includes(cleanDomain)) { exists = true; break; }\n}\n\nif (exists) { staticData.skippedDomains.push(cleanDomain); }\nreturn { json: { ...person, duplicate: exists, skip_silently: false } };"
      },
