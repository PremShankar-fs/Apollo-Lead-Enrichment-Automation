        "jsCode": "const webhookData = $('Webhook1').first().json;\n\nconst targetRow = String(webhookData.body?.targetRow || webhookData.query?.targetRow || '');\n\nif (!targetRow) {\n  return $input.all();\n}\n\nconst filtered = [];\n\nfor (const item of $input.all()) {\n\n  const row =\n    item.json.row_number ||\n    item.json.rowNumber ||\n    item.json.row ||\n    item.json.id ||\n    '';\n\n  if (String(row) === targetRow) {\n    filtered.push(item);\n  }\n}\n\nreturn filtered;"
