      "id": "ded2fd5d-0b02-4a42-b12d-6f89d5309c4f",
      "name": "MailMeteor API1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        41776,
        17296
      ]
    },
    {
      "parameters": {
        "jsCode": "const mmResponse = $input.item.json;\nconst personData = $('Normalize Single Data1').item.json;\n\nlet finalData = { ...personData };\n\nif (mmResponse.success && mmResponse.email) {\n  finalData.verified_email = mmResponse.email;\n  finalData.enrichment_status = 'verified_via_' + mmResponse.source;\n  // Re-evaluate missing data now that we have an email.\n  // If linkedin was also missing, this will STILL be true, which is correct.\n  finalData.has_missing_data = (!finalData.verified_email || !finalData.linkedin_url);\n}\n\nreturn { json: finalData };"
      },
