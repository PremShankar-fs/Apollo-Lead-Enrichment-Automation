    {
      "parameters": {
        "jsCode": "let results = [];\nlet items = $input.all();\nfor (let i = 0; i < items.length; i++) {\n  const people = items[i].json.people || [];\n  const targetTitles = [\"Founder\", \"CEO\", \"CTO\", \"Engineering Manager\", \"VP Engineering\"];\n  let selected = [];\n  let usedTitles = new Set();\n  let usedIds = new Set();\n\n  for (let target of targetTitles) {\n    let person = people.find(p => p.title && p.title.toLowerCase().includes(target.toLowerCase()) && !usedIds.has(p.id));\n    if (person) {\n      selected.push(person);\n      usedTitles.add(person.title);\n      usedIds.add(person.id);\n    }\n  }\n  if (selected.length < 5) {\n    for (let person of people) {\n      if (!usedIds.has(person.id) && person.title && !usedTitles.has(person.title)) {\n        selected.push(person);\n        usedTitles.add(person.title);\n        usedIds.add(person.id);\n        if (selected.length >= 5) break;\n      }\n    }\n  }\n  if (selected.length < 5) {\n    for (let person of people) {\n      if (!usedIds.has(person.id)) {\n        selected.push(person);\n        usedIds.add(person.id);\n        if (selected.length >= 5) break;\n      }\n    }\n  }\n  selected.forEach((p, idx) => {\n    p.is_last_item = (idx === selected.length - 1);\n    results.push({ json: p, pairedItem: { item: i } });\n  });\n}\nreturn results;"
      },
