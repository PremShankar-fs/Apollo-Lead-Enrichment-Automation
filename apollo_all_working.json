        40992,
        17664
      ]
    },
    {
      "parameters": {
        "jsCode": "const matchResponse = $json.matches || [];\nlet match = $json.person || (matchResponse.length > 0 ? matchResponse[0] : {});\n\nlet org = {};\ntry {\n  const orgItem = $('Apollo Organization Search1').item;\n  if (orgItem && orgItem.json && orgItem.json.organizations && orgItem.json.organizations.length > 0) {\n    org = orgItem.json.organizations[0];\n  }\n} catch (e) {\n  // fallback if item pairing fails\n}\n\nconst company = {\n  company_name: org?.name || $('Clean URL1').item?.json?.company_name || '',\n  company_url: org?.website_url || $('Clean URL1').item?.json?.company_url || '',\n  employee_count: org?.estimated_num_employees || '',\n  industry: org?.industry || '',\n};\n\nconst today = new Date().toISOString().split('T')[0];\nconst email = match.email || (match.person ? match.person.email : '') || '';\nconst linkedin = match.linkedin_url || (match.person ? match.person.linkedin_url : '') || '';\n\nconst is_email_missing = !email;\nconst is_linkedin_missing = !linkedin;\nconst has_missing_data = is_email_missing || is_linkedin_missing;\n\nreturn {\n  json: {\n    company_name: company.company_name,\n    company_url: company.company_url,\n    employee_count: company.employee_count,\n    industry: company.industry,\n    first_name: match.first_name || '',\n    last_name: match.last_name || '',\n    designation: match.title || '',\n    partial_email: email,\n    verified_email: email,\n    linkedin_url: linkedin,\n    apollo_person_id: match.id || '',\n    enrichment_status: 'verified',\n    enriched_at: today,\n    has_missing_data: has_missing_data,\n    is_email_missing: is_email_missing,\n    is_linkedin_missing: is_linkedin_missing,\n    is_last_item: $node[\"Split In Batches1\"].context.noItemsLeft\n  }\n};"
      },
